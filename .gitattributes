# Auto-detect text files and normalize line endings to LF on checkout
* text=auto eol=lf

# Explicitly declare source files as text
*.cpp        text eol=lf
*.h          text eol=lf
*.cs         text eol=lf
*.uproject   text eol=lf
*.uplugin    text eol=lf
*.ini        text eol=lf
*.cfg        text eol=lf
*.txt        text eol=lf
*.md         text eol=lf
*.json       text eol=lf
*.xml        text eol=lf
*.yaml       text eol=lf
*.yml        text eol=lf
*.sh         text eol=lf
*.bat        text eol=crlf

# Binary files — never touch these
*.uasset     binary
*.umap       binary
*.fbx        binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.tga        binary
*.bmp        binary
*.dds        binary
*.hdr        binary
*.exr        binary
*.mp3        binary
*.wav        binary
*.ogg        binary
*.mp4        binary
*.mov        binary
*.ttf        binary
*.otf        binary
*.ico        binary
*.lib        binary
*.dll        binary
*.dylib      binary
*.exe        binary
*.a          binary
*.pdb        binary
*.zip        binary